{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug STM32F405",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/main.elf",
      "request": "launch",
      "type": "cortex-debug",
      "servertype": "openocd",
      "device": "STM32F405RG",
      "interface": "swd",
      "configFiles": ["interface/stlink.cfg", "target/stm32f4x.cfg"],
      "runToEntryPoint": "main",
      "showDevDebugOutput": "none"
    }
  ]
}
